{
  "name": "pincerpay",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @pincerpay/db generate",
    "db:migrate": "pnpm --filter @pincerpay/db migrate",
    "db:push": "pnpm --filter @pincerpay/db push",
    "db:seed": "tsx packages/db/src/seed.ts",
    "deploy:dashboard": "source apps/dashboard/.vercel/env.sh && vercel --prod",
    "deploy:agent-demo": "source apps/agent-demo/.vercel/env.sh && vercel --prod",
    "deploy:facilitator": "railway up",
    "screenshots": "tsx scripts/screenshots.ts",
    "create-api-key": "tsx scripts/create-api-key.mts",
    "create-wallets": "tsx scripts/create-wallets.mts",
    "bootstrap-merchant": "tsx scripts/bootstrap-merchant.mts",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-plugin-version.mjs",
    "release": "pnpm build && pnpm test && changeset publish"
  },
  "pnpm": {
    "overrides": {
      "bn.js@>=5 <5.2.3": "5.2.3",
      "minimatch@<10.2.3": "10.2.3",
      "hono@<4.12.4": "4.12.4",
      "rollup@>=4 <4.59.0": "4.59.0",
      "express-rate-limit@>=8.2.0 <8.2.2": "8.2.2"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@pincerpay/core": "workspace:*",
    "@pincerpay/db": "workspace:*",
    "@pincerpay/onboarding": "workspace:*",
    "@playwright/test": "^1.50",
    "drizzle-orm": "^0.38",
    "postgres": "^3.4",
    "tsx": "^4",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
