# Facilitator Configuration
PORT=4402
NODE_ENV=development
LOG_LEVEL=info

# Database (Supabase PostgreSQL direct connection)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# CORS allowed origins (comma-separated). REQUIRED in production —
# the facilitator refuses to start with wildcard CORS in NODE_ENV=production.
# CORS_ORIGINS=https://pincerpay.com,https://demo.pincerpay.com,https://api.yourdomain.com

# Facilitator wallet (EVM) — used to broadcast transactions. Optional.
# Generate with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# FACILITATOR_PRIVATE_KEY=0x...

# Supported EVM networks (comma-separated CAIP-2 IDs). Optional.
# Testnet: eip155:84532 (Base Sepolia), eip155:80002 (Polygon Amoy)
# Mainnet: eip155:8453 (Base), eip155:137 (Polygon)
# EVM_NETWORKS=eip155:84532

# Facilitator wallet (Solana) — base58-encoded 64-byte keypair.
# At least one of SOLANA_PRIVATE_KEY or KORA_RPC_URL is required.
# SOLANA_PRIVATE_KEY=...

# Supported Solana networks (comma-separated CAIP-2 IDs).
# Devnet: solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
# Mainnet: solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
SOLANA_NETWORKS=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# Custom RPC URLs (JSON, optional — works for both EVM and Solana)
# RPC_URLS={"eip155:84532":"https://sepolia.base.org","solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1":"https://api.devnet.solana.com"}

# Kora gasless mode (optional — enables agents paying USDC for gas instead of SOL)
# Deploy Kora signer node from infra/kora/, then set these:
# KORA_RPC_URL=http://kora.railway.internal:8080
# KORA_API_KEY=your-kora-api-key

# Anchor program — enables on-chain settlement recording and direct settlement.
# ANCHOR_PROGRAM_ID=E53zfNo9DYxAUCu37bA2NakJMMbzPFszjgB5kPaTMvF3

# ─── Self-serve onboarding (S13) ───
# Required to mount /v1/onboarding/* routes. If any of these three are missing,
# the facilitator logs `onboarding_disabled_missing_config` and skips the routes.

# HMAC pepper for CLI bearer tokens. At least 32 chars.
# Generate with: openssl rand -base64 48
TOKEN_PEPPER=

# Supabase project URL.
SUPABASE_URL=https://[PROJECT].supabase.co

# Supabase publishable / anon key (sb_publishable_*).
SUPABASE_PUBLISHABLE_KEY=

# ─── OFAC compliance (optional) ───
# When enabled, settlement routes screen `from`/`to` addresses against the
# Treasury SDN list. Refresh interval defaults to 24h.
# OFAC_ENABLED=false
# OFAC_REFRESH_INTERVAL_MS=86400000

# ─── Observability ───
# Better Stack (Logtail) source token — enables log aggregation when set.
# LOGTAIL_SOURCE_TOKEN=

# ─── Operational tuning ───
# Graceful shutdown timeout in milliseconds.
SHUTDOWN_TIMEOUT_MS=10000

# Rate limiting (per minute, per API key).
RATE_LIMIT_PER_MINUTE=120
